import java.sql.*;
import java.util.Scanner;

public class Réponse {

    public static String[] question(ResultSet res, int nbquest) throws SQLException {

        Scanner sc = new Scanner(System.in);
        
        String[] chapitres = new String[30]; 
        int[] scores = new int[30];
        int nbChapitres = 0;
        int[] questchap = new int[30];
        String[] aReviser = new String[30];
        int nbReviser = 0;

        while (res.next()) {
        	
        	String chapitre = res.getString("chapitre");
        	
            System.out.println("\nQuestion : " + res.getString("question"));
           	System.out.print("Entrer votre réponse (A/B/C/D) : ");
           	
           	int index = -1;
            for (int i = 0; i < nbChapitres; i++) {
                if (chapitres[i].equals(chapitre)) {
                    index = i;
                    break;
                }
            }
            
            if (index == -1) {
                chapitres[nbChapitres] = chapitre;
                scores[nbChapitres] = 0;
                questchap[nbChapitres] = 0;
                index = nbChapitres;
                nbChapitres++;
            }
            String reponse;
            
            // Validation de la saisie
            do {
            	reponse = sc.nextLine().trim().toUpperCase();
            	if(!reponse.matches("[ABCD]")) {
            	
            		System.out.println("Entrer A, B, C, ou D");
            	}
            } while(!reponse.matches("[ABCD]"));
            
            String bonneReponse = res.getString("reponse");
            
            
            // Vérification de la reponse
            if (reponse.equals(bonneReponse)) {
            	
    			System.out.println("✔ Correct !");
    			scores[index]++;
    			questchap[index]++;
    			
    		} else {
    			System.out.println("❌ Faux ! Bonne réponse : " + bonneReponse);
    			questchap[index]++;
    		}
        }
        // Affichage des scores
        int total = 0;
        
        System.out.println("\nScores par chapitre :");
        for (int i = 0; i < nbChapitres; i++) {
            System.out.println(chapitres[i] + " : " + scores[i] + "/" + questchap[i]);
            total += scores[i];
        } 
        
        System.out.println("\nScore total : " + total + "/" + nbquest );
        
       
        
        System.out.println("Nous vous conseillons de réviser les chapitres suivants : ");
        for (int i = 0; i < nbChapitres; i++) {
        	if(2*scores[i] < questchap[i] ) {
        		System.out.println(chapitres[i]);
        		aReviser[nbReviser] = chapitres[i];
        		nbReviser ++;
        	}
       	}
        
        
        sc.close();
        
        if (nbReviser == 0) {
            return new String[] { "Aucun chapitre à réviser" };
        }

        String[] resultat = new String[nbReviser];

        for (int i = 0; i < nbReviser; i++) {
            resultat[i] = aReviser[i];
        }

        return resultat;
    
    }
}
